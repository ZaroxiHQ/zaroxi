# Aider
# NOTE: allow .aiderignore and .aider.conf.yml to be tracked by git.
# If you intentionally want to ignore Aider files, uncomment the next line:
# .aider*

# Rust
target/
**/*.rs.bk

# IDE specific files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Build artifacts
**/*.o
**/*.so
**/*.dylib

# Coverage
coverage/
*.profraw

# Environment files
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/

# Tree-sitter runtime grammars are COMMITTED so syntax-highlighting tests are
# reproducible in CI without a network/toolchain build step. The blanket
# `**/*.o`, `**/*.so` and `**/*.dylib` rules above would otherwise hide the
# compiled grammar libraries, so re-include them here.
# (Regenerate/refresh with tooling/scripts/prepare-treesitter.sh.)
!crates/zaroxi-core-platform-syntax/runtime/treesitter/grammars/**
# The precompiled .wasm blobs are not used by the dynamic (.so/.dylib/.dll)
# loader — keep them out of the repo to avoid bloat.
crates/zaroxi-core-platform-syntax/runtime/treesitter/grammars/**/*.wasm

# Build artifacts (project-wide)
**/target/
**/dist/

# Frontend
node_modules/
dist/
dist-ssr/
*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor
.idea/
.vscode/
*.swp
*.swo
.aider*